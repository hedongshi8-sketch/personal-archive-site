VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_SUPABASE_PUBLIC_BUCKET=portfolio-public
VITE_GITHUB_COMMENTS_REPO=hedongshi8-sketch/personal-archive-site
# Free Supabase projects cannot raise Storage > Settings > Global file size limit above 50 MB.
# SQL can raise the bucket limit, but it cannot bypass the project-level global limit.
# After upgrading Supabase or moving audio to another object store, set this higher.
VITE_MAX_MUSIC_UPLOAD_MB=50

# Local-only email verification. Put real values in .env.local, never commit them.
GMAIL_ADDRESS=you@example.com
GMAIL_APP_PASSWORD=your-16-character-app-password
AUTH_EMAIL_TO=you@example.com
AUTH_EMAIL_USE_ALIAS=false
EMAIL_STACK_SEND_GMAIL=false
EMAIL_STACK_TRIGGER_AUTH=false
